# Morrow starts in local-only development mode.
MORROW_ENV=development
MORROW_DATA_DIR=.morrow
MORROW_BIND_HOST=127.0.0.1
MORROW_WEB_PORT=3000
MORROW_API_PORT=4100
MORROW_EXTERNAL_NETWORK=disabled

# ── Model providers (server-side only; never sent to the browser) ────────────
# Set only the keys you use. Do NOT commit real values; copy to a local .env.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
# Generic OpenAI-compatible gateway:
# OPENAI_COMPAT_BASE_URL=
# OPENAI_COMPAT_MODEL=
# OPENAI_COMPAT_API_KEY=
# Local, fully private inference (opt-in): point at a running Ollama server.
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=llama3.1

# Deterministic mock provider for development and tests (no network, no keys).
# MOCK_PROVIDER=true
