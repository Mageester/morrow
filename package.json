{
  "name": "morrow",
  "version": "0.1.0-beta.32",
  "private": true,
  "description": "A private, customizable, self-hosted personal AI agent.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo dev --parallel",
    "build": "turbo build",
    "check": "turbo check && node scripts/validate-repository.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "turbo run test",
    "smoke:acceptance-foundation": "node scripts/acceptance-foundation-smoke.mjs",
    "smoke:acceptance-durable": "node scripts/acceptance-foundation-smoke.mjs --scenario durable-autonomy-v1",
    "test:watch": "turbo run test --watch"
  },
  "devDependencies": {
    "turbo": "2.6.3"
  }
}
