+
+function snapshot(id = "mission-created") {
+  return {
+    artifacts: [],
+    attention: [],
+    currentWork: null,
+    milestones: [],
+    recentActivity: [],
+    summary: mission(id),
+    verification: {
+      caveats: [],
+      evidenceCount: 0,
+      state: "not_ready",
+      summary: "Verification has not started.",
+    },
+    version: 1,
+  };
