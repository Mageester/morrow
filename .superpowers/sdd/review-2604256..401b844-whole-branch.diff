++
++.morrow-page .morrow-surface {
++  display: grid;
++  gap: var(--morrow-space-3);
++}
++
++.morrow-eyebrow {
++  color: var(--morrow-accent);
++  font-size: 0.75rem;
++  font-weight: 750;
++  letter-spacing: 0.08em;
++  text-transform: uppercase;
++}
++
