+    expect(() => resolveResumeCursor("-1", undefined)).toThrow();
+  });
+
+  it("queries persisted mission events strictly after the supplied cursor", () => {
+    seedMission();
+    missions.appendEvent(MISSION_ID, "mission.created", "one");
