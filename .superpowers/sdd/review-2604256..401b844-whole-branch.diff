+import type { WebMissionSnapshot } from "@morrow/contracts";
+import { QueryClient, QueryClientProvider } from "@tanstack/react-query";
+import {
+  createMemoryHistory,
+  RouterProvider,
+  type AnyRouter,
+} from "@tanstack/react-router";
