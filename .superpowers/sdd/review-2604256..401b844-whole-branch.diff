+@import "./tokens.css";
+
+*,
+*::before,
+*::after {
+  box-sizing: border-box;
+}
+
+html {
+  background: var(--morrow-bg);
+  color: var(--morrow-text);
+  font-family:
+    Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
+    sans-serif;
+  line-height: 1.5;
+  text-rendering: optimizeLegibility;
+}
+
+body {
+  margin: 0;
+}
+
+:focus-visible {
+  outline: 3px solid var(--morrow-focus);
+  outline-offset: 3px;
+}
+
+.morrow-sr-only {
+  position: absolute;
+  width: 1px;
+  height: 1px;
+  padding: 0;
+  margin: -1px;
+  overflow: hidden;
+  clip: rect(0, 0, 0, 0);
+  white-space: nowrap;
+  border: 0;
+}
+
+.morrow-button {
+  display: inline-flex;
+  min-height: 44px;
+  align-items: center;
+  justify-content: center;
+  gap: var(--morrow-space-2);
+  padding: 0 var(--morrow-space-4);
+  border: 1px solid transparent;
+  border-radius: var(--morrow-radius-sm);
+  font: inherit;
+  font-weight: 650;
+  cursor: pointer;
+  transition:
+    background-color 160ms ease,
+    border-color 160ms ease,
+    color 160ms ease,
+    box-shadow 160ms ease;
+}
+
+.morrow-button[data-size="compact"] {
+  padding-inline: var(--morrow-space-3);
+}
+
+.morrow-button[data-variant="primary"] {
+  color: var(--morrow-on-accent);
+  background: var(--morrow-accent);
+}
+
+.morrow-button[data-variant="primary"]:hover:not(:disabled) {
+  background: var(--morrow-accent-hover);
+}
+
+.morrow-button[data-variant="secondary"] {
+  color: var(--morrow-text);
+  background: var(--morrow-surface);
+  border-color: var(--morrow-border);
+}
+
+.morrow-button[data-variant="ghost"] {
+  color: var(--morrow-text);
+  background: transparent;
+}
+
+.morrow-button[data-variant="danger"] {
+  color: #ffffff;
+  background: var(--morrow-danger);
+}
+
+.morrow-button:disabled {
+  cursor: not-allowed;
+  opacity: 0.55;
+}
+
+.morrow-surface {
+  color: var(--morrow-text);
+  background: var(--morrow-surface);
+  border: 1px solid var(--morrow-border);
+  border-radius: var(--morrow-radius-md);
+}
+
+.morrow-surface[data-variant="subtle"] {
+  background: var(--morrow-surface-subtle);
+}
+
+.morrow-surface[data-variant="raised"] {
+  box-shadow: var(--morrow-shadow-sm);
+}
+
+.morrow-surface[data-padding="small"] {
+  padding: var(--morrow-space-3);
+}
+
+.morrow-surface[data-padding="medium"] {
+  padding: var(--morrow-space-4);
+}
+
+.morrow-surface[data-padding="large"] {
+  padding: var(--morrow-space-5);
+}
+
+.morrow-status-pill {
+  display: inline-flex;
+  align-items: center;
+  min-height: 28px;
+  padding: 0 var(--morrow-space-3);
+  color: var(--morrow-text-muted);
+  background: var(--morrow-surface-subtle);
+  border: 1px solid var(--morrow-border);
+  border-radius: 999px;
+  font-size: 0.8125rem;
+  font-weight: 650;
+}
+
+.morrow-status-pill[data-variant="accent"] {
+  border-color: var(--morrow-accent);
+}
+
+.morrow-status-pill[data-variant="success"] {
+  border-color: var(--morrow-success);
+}
+
+.morrow-status-pill[data-variant="warning"] {
+  border-color: var(--morrow-warning);
+}
+
+.morrow-status-pill[data-variant="danger"] {
+  border-color: var(--morrow-danger);
+}
+
+.morrow-empty-state,
+.morrow-error-card {
+  padding: var(--morrow-space-5);
+  color: var(--morrow-text);
+  background: var(--morrow-surface);
+  border: 1px solid var(--morrow-border);
+  border-radius: var(--morrow-radius-lg);
+}
+
+.morrow-empty-state {
+  display: grid;
+  justify-items: start;
+  gap: var(--morrow-space-3);
