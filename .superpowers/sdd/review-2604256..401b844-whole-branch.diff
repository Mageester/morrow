++  GlobalErrorBoundaryState
++> {
++  override state: GlobalErrorBoundaryState = { failed: false };
++  private readonly fallbackRef = createRef<HTMLElement>();
++  private errorGeneration = 0;
++  private restorationFrame: number | null = null;
