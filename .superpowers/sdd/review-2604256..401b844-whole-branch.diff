++import { AppShell } from "./app-shell.js";
++
++const rootRoute = createRootRoute({ component: AppShell });
++
++const homeRoute = createRoute({
++  component: HomePage,
++  getParentRoute: () => rootRoute,
++  path: "/",
++});
++
++const missionsRoute = createRoute({
