++    flex-direction: column;
++    justify-content: center;
++    gap: 2px;
++    padding: var(--morrow-space-1);
++    font-size: 0.7rem;
++  }
++
++  .morrow-main {
++    padding: var(--morrow-space-5) var(--morrow-space-4);
++  }
++}
