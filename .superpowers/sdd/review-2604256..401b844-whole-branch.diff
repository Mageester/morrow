+
+.morrow-empty-state__description,
+.morrow-error-card__explanation,
+.morrow-artifact-frame__metadata,
+.morrow-timeline__description,
+.morrow-timeline time {
+  color: var(--morrow-text-muted);
+}
+
+.morrow-error-card {
+  border-inline-start: 4px solid var(--morrow-danger);
+}
+
+.morrow-error-card__preserved {
+  font-weight: 650;
+}
+
+.morrow-error-card__actions,
+.morrow-error-card__alternative-actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: var(--morrow-space-2);
+}
+
+.morrow-error-card__actions {
+  align-items: center;
+}
+
+.morrow-error-card ul {
+  padding-inline-start: var(--morrow-space-5);
+}
+
+.morrow-progress-steps,
+.morrow-timeline {
+  padding: 0;
+  margin: 0;
+  list-style: none;
+}
+
+.morrow-progress-steps {
+  display: flex;
+  flex-wrap: wrap;
+  gap: var(--morrow-space-4);
+}
+
+.morrow-progress-steps li {
+  display: inline-flex;
+  align-items: center;
+  gap: var(--morrow-space-2);
+  color: var(--morrow-text-muted);
+}
+
+.morrow-progress-steps li[aria-current="step"] {
+  color: var(--morrow-text);
+  font-weight: 650;
+}
+
+.morrow-progress-steps__marker {
+  width: 10px;
+  height: 10px;
+  background: var(--morrow-surface);
+  border: 2px solid var(--morrow-border);
+  border-radius: 50%;
+}
+
+.morrow-progress-steps li[data-status="complete"]
+  .morrow-progress-steps__marker {
+  background: var(--morrow-success);
+  border-color: var(--morrow-success);
+}
+
+.morrow-progress-steps li[data-status="current"]
+  .morrow-progress-steps__marker {
+  border-color: var(--morrow-accent);
+}
+
+.morrow-timeline {
+  display: grid;
+  gap: var(--morrow-space-4);
+}
+
+.morrow-timeline li {
+  padding-inline-start: var(--morrow-space-4);
+  border-inline-start: 2px solid var(--morrow-border);
+}
+
+.morrow-timeline__heading {
+  display: flex;
+  flex-wrap: wrap;
+  justify-content: space-between;
+  gap: var(--morrow-space-2);
+}
+
+.morrow-artifact-frame {
+  overflow: hidden;
+  color: var(--morrow-text);
+  background: var(--morrow-surface);
+  border: 1px solid var(--morrow-border);
+  border-radius: var(--morrow-radius-md);
+}
+
+.morrow-artifact-frame__header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: var(--morrow-space-4);
+  padding: var(--morrow-space-4);
+  border-block-end: 1px solid var(--morrow-border);
+}
+
+.morrow-artifact-frame__actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: var(--morrow-space-2);
+}
+
+.morrow-artifact-frame__content {
+  padding: var(--morrow-space-4);
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    scroll-behavior: auto !important;
+    animation-duration: 0.01ms !important;
+    animation-iteration-count: 1 !important;
+    transition-duration: 0.01ms !important;
+  }
+}
