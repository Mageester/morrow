+      currentPhase: "Reviewing evidence",
+      id: "mission-42",
+      latestActivity: "Reviewed the launch evidence.",
+      objective: "Prepare an evidence-backed launch brief.",
+      projectId: "project-1",
+      state: "working",
+      title: "Prepare the launch",
+      totalMilestones: 5,
+      updatedAt: "2026-07-21T13:45:00.000Z",
