++            </span>
++          ) : null}
++        </>
++      }
++      explanation={model.explanation}
++      preservedMessage={model.preservedMessage}
++      recommendedAction={recommendedAction}
++      ref={cardRef}
++      tabIndex={-1}
++      title={model.title}
