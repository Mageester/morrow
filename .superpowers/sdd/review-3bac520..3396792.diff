+  width: min(100%, 32rem);
+  gap: var(--morrow-space-4);
+  padding: var(--morrow-space-5);
+  color: var(--morrow-text);
+  background: var(--morrow-surface);
+  border-radius: var(--morrow-radius-md);
+  box-shadow: var(--morrow-shadow-sm);
+}
+
+.morrow-attention-dialog__actions {
+  display: flex;
+  justify-content: flex-end;
+  gap: var(--morrow-space-2);
+}
+
+.morrow-error-reference {
+  display: block;
+  margin-top: var(--morrow-space-2);
+  color: var(--morrow-text-muted);
+  font-family: ui-monospace, monospace;
+  font-size: 0.8125rem;
+  overflow-wrap: anywhere;
+}
+
+.morrow-global-error {
+  width: min(100% - 2 * var(--morrow-space-4), 48rem);
+  padding-block: var(--morrow-space-7);
+  margin-inline: auto;
 }
 
