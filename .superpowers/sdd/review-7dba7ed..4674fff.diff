     expect(tables).toEqual([
       "mission_operations",
       "mission_progress",
       "mission_recovery_decisions",
       "mission_runtime",
       "mission_runtime_transitions",
     ]);
diff --git a/services/orchestrator/test/server-web-missions.test.ts b/services/orchestrator/test/server-web-missions.test.ts
