+  top: 0;
+  display: flex;
+  height: 100vh;
+  flex-direction: column;
+  gap: var(--morrow-space-4);
+  padding: var(--morrow-space-5) var(--morrow-space-3);
+  background: var(--morrow-surface);
+  border-inline-end: 1px solid var(--morrow-border);
+}
+
+.morrow-brand {
+  display: flex;
+  align-items: center;
+  gap: var(--morrow-space-3);
+  padding-inline: var(--morrow-space-2);
+}
+
+.morrow-brand__mark {
+  display: grid;
+  width: 40px;
+  height: 40px;
+  color: var(--morrow-on-accent);
+  background: var(--morrow-accent);
+  border-radius: var(--morrow-radius-md);
+  place-items: center;
+}
+
+.morrow-brand strong,
+.morrow-brand span,
+.morrow-profile {
+  display: block;
+}
+
+.morrow-brand strong {
+  letter-spacing: -0.01em;
+}
+
+.morrow-brand div > span,
+.morrow-profile {
+  color: var(--morrow-text-muted);
+  font-size: 0.75rem;
+}
+
+.morrow-workspace-switcher {
+  display: flex;
+  min-height: 44px;
+  align-items: center;
+  justify-content: space-between;
+  padding: 0 var(--morrow-space-3);
+  color: var(--morrow-text);
+  background: var(--morrow-surface-subtle);
+  border: 1px solid var(--morrow-border);
+  border-radius: var(--morrow-radius-sm);
