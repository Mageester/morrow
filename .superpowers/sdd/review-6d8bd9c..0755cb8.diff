+  min-height: 44px;
+  align-items: center;
+  gap: var(--morrow-space-3);
+  padding: 0 var(--morrow-space-3);
+  color: var(--morrow-text-muted);
+  border-radius: var(--morrow-radius-sm);
+  font-weight: 590;
+  text-decoration: none;
+}
+
+.morrow-nav__link:hover {
+  color: var(--morrow-text);
+  background: var(--morrow-surface-subtle);
+}
+
+.morrow-nav__link[aria-current="page"] {
+  color: var(--morrow-text);
+  background: color-mix(in srgb, var(--morrow-accent) 11%, transparent);
+}
+
+.morrow-nav__link[aria-current="page"] svg {
+  color: var(--morrow-accent);
+}
+
+.morrow-sidebar__footer {
