+    width: 100%;
+    height: auto;
+    padding: var(--morrow-space-2);
+    border-block-start: 1px solid var(--morrow-border);
+    border-inline-end: 0;
+  }
+
+  .morrow-brand,
+  .morrow-workspace-switcher,
+  .morrow-sidebar__footer {
+    display: none;
+  }
+
+  .morrow-nav {
+    display: flex;
+    overflow-x: auto;
+    scrollbar-width: thin;
+  }
+
+  .morrow-nav__group {
+    display: flex;
+  }
+
