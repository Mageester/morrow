+
+.morrow-nav,
+.morrow-nav__group {
+  display: grid;
+  gap: var(--morrow-space-1);
+}
+
+.morrow-nav__group--secondary {
+  padding-top: var(--morrow-space-4);
+  margin-top: var(--morrow-space-3);
+  border-top: 1px solid var(--morrow-border);
+}
+
+.morrow-nav__link {
