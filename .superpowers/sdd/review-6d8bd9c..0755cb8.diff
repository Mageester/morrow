+  position: fixed;
+  z-index: 10;
+  top: var(--morrow-space-3);
+  left: var(--morrow-space-3);
+  padding: var(--morrow-space-2) var(--morrow-space-3);
+  color: var(--morrow-on-accent);
+  background: var(--morrow-accent);
+  border-radius: var(--morrow-radius-sm);
+  transform: translateY(-160%);
+}
+
+.morrow-skip-link:focus {
+  transform: translateY(0);
+}
+
+.morrow-app-shell {
+  display: grid;
+  grid-template-columns: 248px minmax(0, 1fr);
+  min-height: 100vh;
+}
+
